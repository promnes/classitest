{
  "name": "Classify — منصة تعليمية تفاعلية للأطفال",
  "short_name": "Classify",
  "description": "منصة تعليمية ممتعة للأطفال مع رقابة أبوية ذكية وألعاب تفاعلية — Fun educational platform for kids with smart parental controls and interactive games",
  "lang": "ar",
  "dir": "auto",
  "start_url": "/",
  "scope": "/",
  "id": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui", "window-controls-overlay"],
  "background_color": "#ffffff",
  "theme_color": "#6B4D9D",
  "orientation": "portrait-primary",
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "scope_extensions": [
    { "origin": "https://classi-fy.com" }
  ],
  "note_taking": {
    "new_note_url": "/child-tasks?action=new"
  },
  "file_handlers": [
    {
      "action": "/child-games",
      "accept": {
        "application/json": [".json"],
        "text/plain": [".txt", ".csv"]
      },
      "icons": [
        { "src": "/icons/icon-96.png", "sizes": "96x96", "type": "image/png" }
      ],
      "launch_type": "single-client"
    }
  ],
  "widgets": [
    {
      "name": "Classify Tasks",
      "short_name": "Tasks",
      "description": "عرض مهام الطفل — View child tasks",
      "tag": "classify-tasks",
      "ms_ac_template": "widget/tasks",
      "data": "/api/child/tasks",
      "type": "application/json",
      "screenshots": [
        { "src": "/screenshots/mobile-home.png", "sizes": "540x1200", "label": "Tasks Widget" }
      ],
      "icons": [
        { "src": "/icons/icon-96.png", "sizes": "96x96", "type": "image/png" }
      ],
      "backgrounds": [
        { "src": "/icons/icon-512.png", "sizes": "512x512", "type": "image/png" }
      ]
    }
  ],
  "tab_strip": {
    "home_tab": {
      "scope_patterns": [
        { "pathname": "/" },
        { "pathname": "/child-dashboard" },
        { "pathname": "/child-games" }
      ]
    },
    "new_tab_button": {
      "url": "/child-tasks"
    }
  },
  "share_target": {
    "action": "/child-games",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+classify",
      "url": "/%s"
    }
  ],
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.classify.app",
      "id": "com.classify.app"
    },
    {
      "platform": "webapp",
      "url": "https://classi-fy.com/manifest.json"
    }
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
